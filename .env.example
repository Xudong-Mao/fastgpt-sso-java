# FastGPT SSO Java 环境配置示例文件
# 复制此文件为 .env 并根据实际环境修改配置
# .env 文件优先级：系统环境变量 > .env 文件 > application.properties 默认值

# ========== 服务器配置 ==========
SERVER_PORT=8080
SPRING_APPLICATION_NAME=fastgpt-sso-java

# ========== 应用基础配置 ==========
# SSO Provider: test(测试) | weaver(泛微)
APP_SSO_PROVIDER=weaver
# 激活 Spring Profile（weaver 时注册 weaversso.jar 的 Filter/Listener）
SPRING_PROFILES_ACTIVE=weaver
# FastGPT 回调认证 Token（用于 /user/list 和 /org/list 接口鉴权）
APP_AUTH_TOKEN=your-auth-token-here
# 是否启用 hostname 重定向
APP_REDIRECT_ENABLED=false
# 重定向目标 hostname（APP_REDIRECT_ENABLED=true 时生效）
APP_HOSTNAME=

# ========== 泛微 Ecology SSO 配置 ==========
# 是否启用泛微 SSO
WEAVER_SSO_ENABLED=true
# CAS 服务端地址（泛微OA地址，必填）
# 如 http://192.168.1.100:8080
WEAVER_SSO_SERVER_URL=http://192.168.1.100:8080
# CAS 登录路径
WEAVER_SSO_LOGIN_PATH=/login/login.jsp
# 应用标识（在泛微统一认证中心注册时分配的 appid）
WEAVER_SSO_APP_ID=fastgpt
# 本服务的外网可达地址（用于CAS回调，必填，泛微需要能访问到此地址）
WEAVER_SSO_SERVER_NAME=http://your-server-host:8080
# 回调接口路径
WEAVER_SSO_CALLBACK_PATH=/login/oauth/callback
# HR 同步接口认证 Token（泛微OA推送数据时携带的鉴权令牌）
WEAVER_SSO_HR_SYNC_TOKEN=your-hr-sync-token-here

# ========== CAS 返回属性映射 ==========
# 用户名字段（CAS Assertion 中对应的属性名）
WEAVER_SSO_ATTR_USERNAME=loginid
# 姓名字段
WEAVER_SSO_ATTR_MEMBER_NAME=lastname
# 邮箱字段
WEAVER_SSO_ATTR_EMAIL=email
# 手机号字段
WEAVER_SSO_ATTR_MOBILE=mobile

# ========== SAML 配置（按需启用） ==========
# SAML_ENTITY_ID=your-entity-id
# SAML_ASSERTION_CONSUMER_SERVICE_URL=http://localhost:8080/login/saml/assert
# SAML_SINGLE_LOGOUT_SERVICE_URL=http://localhost:8080/logout/saml
# SAML_IDP_METADATA_URL=https://your-idp.com/metadata

# ========== OAuth 配置（按需启用） ==========
# OAUTH_CLIENT_ID=your-oauth-client-id
# OAUTH_CLIENT_SECRET=your-oauth-client-secret
# OAUTH_AUTHORIZATION_URI=https://your-oauth-provider.com/oauth/authorize
# OAUTH_TOKEN_URI=https://your-oauth-provider.com/oauth/token
# OAUTH_USER_INFO_URI=https://your-oauth-provider.com/oauth/userinfo

# ========== 测试配置（APP_SSO_PROVIDER=test 时生效） ==========
# TEST_REDIRECT_URI=http://localhost:3000/callback
# TEST_STATE=test-state-123
# TEST_CODE=test-code-456
# TEST_BASE_URL=http://localhost:8080
